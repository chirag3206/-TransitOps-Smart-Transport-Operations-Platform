# Normalize line endings: commit LF, checkout per-OS
* text=auto

# Force LF for JS/JSON/CSS files
*.js    text eol=lf
*.jsx   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.env*  text eol=lf

# Binary files — no text conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.svg   binary
*.ico   binary
*.webp  binary
